---
import '~/styles/global.css';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import { SITE, type Lang } from '~/i18n/ui';

interface Props {
  title: string;
  description: string;
  lang?: Lang;
  /** Locale-relative path of the current page (no /fr prefix), e.g. '/' or '/services'. */
  path?: string;
}
const { title, description, lang = 'en', path = '/' } = Astro.props;
const fullTitle = `${title} — ${SITE.name}`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang={lang} class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {/* hreflang alternates so search engines pair the EN root with its /fr mirror */}
    <link rel="alternate" hreflang="en" href={new URL(path === '/' ? '/' : path, Astro.site).href} />
    <link rel="alternate" hreflang="fr" href={new URL(path === '/' ? '/fr' : '/fr' + path, Astro.site).href} />
    <link rel="alternate" hreflang="x-default" href={new URL(path === '/' ? '/' : path, Astro.site).href} />
    {/* Favicon — same set as nitroxbrain.com */}
    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/images/hero-terminal.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <!-- Reason: set the theme class before paint to avoid a light/dark flash. Default dark. -->
    <script is:inline>
      (function () {
        try {
          const saved = localStorage.getItem('nx-theme');
          if (saved === 'light') document.documentElement.classList.remove('dark');
          else document.documentElement.classList.add('dark');
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen">
    <Header lang={lang} path={path} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
