---
interface Action {
  label: string;
  href: string;
  variant?: 'primary' | 'ghost';
}
interface Props {
  tagline?: string;
  title: string;
  subtitle?: string;
  actions?: Action[];
}
const { tagline, title, subtitle, actions = [] } = Astro.props;
---

<section class="relative isolate overflow-hidden">
  <!-- Hero background: the dark trading-terminal screen -->
  <div class="absolute inset-0 -z-10">
    <img
      src="/images/hero-terminal.png"
      alt=""
      class="h-full w-full object-cover"
      loading="eager"
      decoding="async"
    />
    <!-- Light wash + a left-side gradient: keeps the headline legible while
         letting much more of the terminal image show through on the right. -->
    <div class="absolute inset-0 bg-charcoal-950/35"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-charcoal-950/80 via-charcoal-950/25 to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-charcoal-950 to-transparent"></div>
  </div>

  <div class="mx-auto max-w-6xl px-4 py-32 sm:px-6 sm:py-40 lg:py-48">
    <div class="max-w-2xl">
      {tagline && <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-brand-400">{tagline}</p>}
      <h1 class="text-4xl font-bold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl">
        <Fragment set:html={title} />
      </h1>
      {subtitle && <p class="mt-6 max-w-xl text-lg leading-relaxed text-gray-300">{subtitle}</p>}
      {
        actions.length > 0 && (
          <div class="mt-8 flex flex-wrap gap-3">
            {actions.map((a) =>
              a.variant === 'ghost' ? (
                <a
                  href={a.href}
                  class="rounded-md border border-white/25 px-5 py-2.5 text-base font-medium text-white hover:border-brand-400 hover:text-brand-400"
                >
                  {a.label}
                </a>
              ) : (
                <a
                  href={a.href}
                  class="rounded-md bg-brand-500 px-5 py-2.5 text-base font-semibold text-white hover:bg-brand-600"
                >
                  {a.label}
                </a>
              )
            )}
          </div>
        )
      }
    </div>
  </div>
</section>
