---
import { Icon } from 'astro-icon/components';

interface Item {
  title: string;
  description: string;
  icon?: string;
}
interface Props {
  items: Item[];
  columns?: 2 | 3;
}
const { items, columns = 3 } = Astro.props;
const gridCls = columns === 2 ? 'sm:grid-cols-2' : 'sm:grid-cols-2 lg:grid-cols-3';
---

<div class={`grid grid-cols-1 gap-6 ${gridCls}`}>
  {
    items.map((item) => (
      <div class="rounded-xl border border-token bg-surface p-6 transition-colors hover:border-primary/50">
        {item.icon && (
          <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-lg bg-primary/10 text-primary">
            <Icon name={item.icon} class="h-6 w-6" />
          </div>
        )}
        <h3 class="text-lg font-semibold">{item.title}</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted" set:html={item.description} />
      </div>
    ))
  }
</div>
