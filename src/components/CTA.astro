---
interface Action {
  label: string;
  href: string;
  variant?: 'primary' | 'ghost';
}
interface Props {
  title: string;
  subtitle?: string;
  actions?: Action[];
}
const { title, subtitle, actions = [] } = Astro.props;
---

<section>
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="overflow-hidden rounded-2xl border border-token bg-charcoal-900 px-6 py-12 text-center sm:px-12">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">{title}</h2>
      {subtitle && <p class="mx-auto mt-4 max-w-xl text-lg text-gray-300">{subtitle}</p>}
      {
        actions.length > 0 && (
          <div class="mt-8 flex flex-wrap justify-center gap-3">
            {actions.map((a) =>
              a.variant === 'ghost' ? (
                <a
                  href={a.href}
                  class="rounded-md border border-white/25 px-5 py-2.5 text-base font-medium text-white hover:border-brand-400 hover:text-brand-400"
                >
                  {a.label}
                </a>
              ) : (
                <a
                  href={a.href}
                  class="rounded-md bg-brand-500 px-5 py-2.5 text-base font-semibold text-white hover:bg-brand-600"
                >
                  {a.label}
                </a>
              )
            )}
          </div>
        )
      }
    </div>
  </div>
</section>
